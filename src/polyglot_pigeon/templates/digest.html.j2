<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: Georgia, 'Times New Roman', serif;
      max-width: 680px;
      margin: 0 auto;
      padding: 20px;
      line-height: 1.7;
      color: #333;
    }
    h1 { font-size: 1.8em; color: #1a1a2e; margin-top: 0; }
    h2 {
      font-size: 1.4em;
      color: #1a1a2e;
      border-bottom: 2px solid #ddd;
      padding-bottom: 6px;
      margin-top: 2em;
    }
    h3 { font-size: 1.1em; color: #1a1a2e; }
    hr { border: none; border-top: 2px solid #ddd; margin: 24px 0; }
    strong { color: #1a1a2e; }
    em { color: #555; }
    p { margin: 0.7em 0; }
    .header {
      text-align: center;
      padding: 24px 0 16px;
      border-bottom: 2px solid #ddd;
      margin-bottom: 24px;
    }
    .header img { width: 80px; height: 80px; object-fit: contain; display: block; margin: 0 auto 12px; }
    .header .project-name { font-size: 1.3em; font-weight: bold; color: #1a1a2e; margin: 0 0 4px; }
    .header .digest-title { font-size: 1em; color: #555; margin: 0 0 4px; }
    .header .digest-date { font-size: 0.85em; color: #888; margin: 0; }
    .footer { margin-top: 2em; padding-top: 1em; border-top: 1px solid #ddd; font-size: 0.75em; color: #aaa; }
  </style>
</head>
<body>

  <div class="header">
    {% if logo_cid %}
      <img src="cid:{{ logo_cid }}" alt="Polyglot Pigeon logo">
    {% endif %}
    <p class="project-name">Polyglot Pigeon</p>
    <p class="digest-title">{{ title }}</p>
    <p class="digest-date">{{ date }}</p>
  </div>

  <p>{{ content.introduction }}</p>

  {% for article in content.articles %}
    {% if not loop.first %}<hr>{% endif %}

    <h3>{{ article.title }}</h3>
    <p><em>{{ article.source }} &middot; {{ article.date }}</em></p>
    <p>{{ article.content }}</p>

    {% if article.glossary %}
      <hr>
      {% for word, translation in article.glossary.items() %}
        <p><strong>{{ word }}</strong>: {{ translation }}</p>
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if cost_info %}
  <div class="footer">{{ cost_info }}</div>
  {% endif %}

</body>
</html>
